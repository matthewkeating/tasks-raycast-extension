{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "tasks",
  "title": "Tasks",
  "description": "Manage your Tasks app task list",
  "icon": "extension-icon.png",
  "author": "mattkeating",
  "categories": ["Productivity"],
  "license": "MIT",
  "commands": [
    {
      "name": "add-task",
      "title": "Add Task",
      "description": "Add a new task",
      "mode": "view"
    },
    {
      "name": "list-tasks",
      "title": "List Tasks",
      "description": "List and manage your tasks",
      "mode": "view"
    },
    {
      "name": "complete-task",
      "title": "Complete Task",
      "description": "Mark a task as complete",
      "mode": "view"
    },
    {
      "name": "flag-task",
      "title": "Flag Task",
      "description": "Flag or unflag a task",
      "mode": "view"
    },
    {
      "name": "delete-task",
      "title": "Delete Task",
      "description": "Delete a task",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.82.0"
  },
  "devDependencies": {
    "@types/node": "^20.8.10",
    "@types/react": "18.3.3",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
